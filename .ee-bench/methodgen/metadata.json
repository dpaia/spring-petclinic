{
  "version": "1.0",
  "benchmark_type": "methodgen",
  "language": "java",
  "jvm_version": "17",
  "target": {
    "file": "src/main/java/org/springframework/samples/petclinic/owner/PetTypeFormatter.java",
    "method_signature": "parse(String,Locale)",
    "stub": "@Override\npublic PetType parse(String text, Locale locale) throws ParseException {}",
    "validations": [
      {"type": "contains", "scope": "method_text", "pattern": "@Override"},
      {"type": "contains", "scope": "body_text", "pattern": "findPetTypes\\(\\)"},
      {"type": "contains", "scope": "body_text", "pattern": "ParseException"},
      {"type": "test", "test_class": "org.springframework.samples.petclinic.owner.PetTypeFormatterParseTest"}
    ]
  },
  "environment": {
    "project_root": "/repo",
    "docker": {
      "run_params": {
        "privileged": true,
        "network": "host",
        "volumes": ["/var/run/docker.sock:/var/run/docker.sock"],
        "environment": {
          "TESTCONTAINERS_RYUK_DISABLED": "true",
          "TESTCONTAINERS_CHECKS_DISABLE": "true",
          "DOCKER_HOST": "unix:///var/run/docker.sock"
        }
      }
    }
  }
}
