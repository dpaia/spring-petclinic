{
  "version": "1.0",
  "benchmark_type": "methodgen",
  "language": "java",
  "jvm_version": "17",
  "target": {
    "file": "src/main/java/org/springframework/samples/petclinic/owner/OwnerController.java",
    "method_signature": "addPaginationModel(int,Model,Page)",
    "stub": "String addPaginationModel(int page, Model model, Page paginated) {}",
    "validations": [
      {"type": "contains", "scope": "body_text", "pattern": "getContent\\(\\)"},
      {"type": "contains", "scope": "body_text", "pattern": "addAttribute.*current"},
      {"type": "contains", "scope": "body_text", "pattern": "addAttribute.*total"},
      {"type": "contains", "scope": "body_text", "pattern": "addAttribute.*wners"},
      {"type": "contains", "scope": "body_text", "pattern": "owners/ownersList"}
    ]
  },
  "environment": {
    "project_root": "/repo",
    "docker": {
      "run_params": {
        "privileged": true,
        "network": "host",
        "volumes": ["/var/run/docker.sock:/var/run/docker.sock"],
        "environment": {
          "TESTCONTAINERS_RYUK_DISABLED": "true",
          "TESTCONTAINERS_CHECKS_DISABLE": "true",
          "DOCKER_HOST": "unix:///var/run/docker.sock"
        }
      }
    }
  }
}
